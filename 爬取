    "def find_xml_item(url):\n",
    "    try:\n",
    "        bs = request_get_bs(url, docu_parser=\"xml\")\n",
    "        items = []\n",
    "        # print(bs)\n",
    "        for item in bs.find_all(\"item\"):\n",
    "            item_data = {}\n",
    "            item_data['title'] = item.title.text.strip() if item.title else None\n",
    "            item_data['link'] = item.link.text.strip().replace(\"http\", \"https\") if item.link else None\n",
    "            # item_data['guid'] = item.guid.text.strip().replace(\"http\", \"https\") if item.guid else None\n",
    "            item_data['pubDate'] = item.pubDate.text.strip() if item.pubDate else None\n",
    "            item_data['dc_date'] = item.find('dc:date').text.strip() if item.find('dc:date') else None\n",
    "            if item.description:\n",
    "                desc_soup = BeautifulSoup(unescape(item.description.text), 'html.parser')\n",
    "                # 提取作者\n",
    "                authors = []\n",
    "                for span in desc_soup.find_all('span'):\n",
    "                    if span.text and 'person' in span.parent.get('class', []):\n",
    "                        # print(span.parent)\n",
    "                        authors.append({\n",
    "                            \"name\": span.text.strip(),\n",
    "                            \"url\": span.parent.get(\"href\", \"\").strip().replace(\"http\", \"https\")\n",
    "                        })\n",
    "                item_data['authors'] = authors\n",
    "                \n",
    "                # 提取项目类型\n",
    "                type_span = desc_soup.find('span', class_='type_classification')\n",
    "                item_data['project_type'] = type_span.text.strip() if type_span else None\n",
    "                \n",
    "                # 提取日期范围\n",
    "                dates = desc_soup.find_all('span', class_='date')\n",
    "                for ind in range(len(dates)):\n",
    "                    item_data[f'desc_date_{ind}'] = dates[ind].text.strip()\n",
    "            \n",
    "            items.append(item_data)\n",
    "        # return\n",
    "        return items\n",
    "    except Exception as e:\n",
    "        traceback.print_exc()\n",
    "        raise Exception(f\"find_xml_item: Error in {url}\")"
   ]
  },
