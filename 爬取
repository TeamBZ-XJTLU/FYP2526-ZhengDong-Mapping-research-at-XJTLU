    "def find_part_info(bs_obj, key_string, separate = False, first = \"h3\", follow = \"div\", direction_down = True):\n",
    "    first_box = bs_obj.find(first, string=key_string)\n",
    "    if not first_box:\n",
    "        return [] if separate else None\n",
    "    if direction_down:\n",
    "        next_box = first_box.find_next(follow)\n",
    "    else:\n",
    "        next_box = first_box.find_previous(follow)\n",
    "    if separate:\n",
    "        res_list = []\n",
    "        for each in next_box.children:\n",
    "            res_list.append(each.text.strip()) if each.text.strip() else None\n",
    "        return res_list\n",
    "    else:\n",
    "        return next_box.text.strip()"
   ]
