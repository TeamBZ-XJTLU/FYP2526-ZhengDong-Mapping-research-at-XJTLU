    "def find_finger_prints(url):\n",
    "    try:\n",
    "        bs = request_get_bs(url)\n",
    "        tag_boxes = bs.find_all(\"div\", class_ = \"person-fingerprint-thesauri\")\n",
    "        if not tag_boxes:\n",
    "            return []\n",
    "        result = []\n",
    "        for tag_box in tag_boxes:\n",
    "            # print(tag.find(\"h3\").text)\n",
    "            tags = tag_box.find(\"ol\").find_all(\"li\")\n",
    "            for tag in tags:\n",
    "                value = round(float(tag.find(\"button\").get(\"data-rank-value\")), 2)\n",
    "                name = tag.find(\"span\", class_=\"concept\").text.strip()\n",
    "                result.append([name, value])\n",
    "        return result\n",
    "    except Exception as e:\n",
    "        traceback.print_exc()\n",
    "        raise Exception(f\"find_finger_prints: Error in {url}\")"
   ]
  },
