    "def find_project_detail(url):\n",
    "    try:\n",
    "        if not url:\n",
    "            return {}\n",
    "        bs = request_get_bs(url)\n",
    "        res = {}\n",
    "        # relations organisations\n",
    "        res[\"org\"] = [each.text.strip() for each in bs.find_all(\"a\", rel = \"Organisation\")]\n",
    "        # type_family\n",
    "        _box = bs.find(\"span\", class_=\"type_family\")\n",
    "        res[\"type_family\"] = _box.text.strip().replace(\":\",\"\") if _box else None\n",
    "        # type_classification\n",
    "        res[\"type_classification\"] = _box.parent.text.strip() if _box else None\n",
    "        # fund amount\n",
    "        fund_box = bs.find(\"div\", class_=\"fund_amount_rmb\")\n",
    "        res[\"fund\"] = fund_box.find(\"div\", class_=\"textblock\").text.strip() if fund_box else None\n",
    "        # abstract, description\n",
    "        abs_h2 = bs.find(\"h2\", string=\"Abstract\")\n",
    "        des_h3 = bs.find(\"h3\", string=\"Description\")\n",
    "        if abs_h2:\n",
    "            word_box = abs_h2.find_next_sibling(\"div\", class_=\"textblock\")\n",
    "            res[\"abstract\"] = word_box.text.strip() if word_box else None\n",
    "        if des_h3:\n",
    "            word_box = des_h3.find_next_sibling(\"div\", class_=\"textblock\")\n",
    "            res[\"abstract\"] = word_box.text.strip() if word_box else None\n",
    "        content_area = bs.find(class_=\"content-content\")\n",
    "        # 提取中间meta信息\n",
    "        # 遍历table的每个tr，提取th:td\n",
    "        for table_box in content_area.find_all(\"table\"):\n",
    "            for row_ in table_box.find_all(\"tr\"):\n",
    "                res[row_.find(\"th\").text.strip()] = row_.find(\"td\").text.strip()\n",
    "        # 遍历ul每个li，提取keyword\n",
    "        keyword_list = []\n",
    "        key_box = content_area.find(\"ul\", class_ = \"relations keywords\")\n",
    "        if key_box:\n",
    "            for keyword in key_box.find_all(\"li\"):\n",
    "                keyword_list.append(keyword.text.strip())\n",
    "        res[\"keywords\"] = keyword_list\n",
    "        # cite BIBTEX\n",
    "        bib_cite_box = bs.find(\"div\", id=\"cite-BIBTEX\")\n",
    "        res[\"bibtex\"] = bib_cite_box.text.strip() if bib_cite_box else None\n",
    "        return res\n",
    "    except Exception as e:\n",
    "        traceback.print_exc()\n",
    "        raise Exception(f\"find_project_detail: Error in {url}\")"
   ]
  },
