    "def get_tutor_overview(overview_url):\n",
    "    tbs = request_get_bs(overview_url)\n",
    "    tinfo = {}\n",
    "    tinfo[\"Url\"] = overview_url\n",
    "    # Name\n",
    "    name_h1 = tbs.find(\"div\", class_=\"header person-details\").find(\"h1\")\n",
    "    tinfo[\"Name\"] = name_h1.text.strip()\n",
    "    # Image\n",
    "    pic_box = tbs.find(\"picture\")\n",
    "    pic_url = None\n",
    "    if pic_box:\n",
    "        pic_url = \"https://scholar.xjtlu.edu.cn/files-asset/{}/testfilename.jpg\".format(pic_box.find(\"source\").get(\"srcset\").split(\"/\")[2])\n",
    "    tinfo[\"Image Url\"] = pic_url if pic_url else None\n",
    "    # Role\n",
    "    role_box = name_h1.find_next_sibling(\"div\")\n",
    "    tinfo[\"Role\"] = role_box.find(\"p\").text.strip() if role_box else None\n",
    "    # Department\n",
    "    dep_box = role_box.find_next_sibling(\"div\")\n",
    "    dep_lis = dep_box.find(\"ul\").find(\"li\") if dep_box else []\n",
    "    tinfo[\"Department\"] = dep_lis.text.strip() if dep_lis else None\n",
    "    # Phone\n",
    "    tinfo[\"Phone\"] = find_part_info(tbs, \"Phone\", separate=False, first=\"span\", follow=\"span\", direction_down=True)\n",
    "    # Email\n",
    "    email_box = tbs.find(\"span\", string=\"Email\")\n",
    "    email_str = \"\"\n",
    "    if email_box:\n",
    "        email_box = email_box.find_next(\"a\")\n",
    "        if email_box:\n",
    "            for each in email_box.children:\n",
    "                email_str += each.text.replace(\"encryptedA();\",\"@\").replace(\"encryptedDot();\",\".\")\n",
    "    email_str = email_str if email_str else None\n",
    "    tinfo[\"Email\"] = email_str\n",
    "    # Citation\n",
    "    tinfo[\"Citation\"] = find_part_info(tbs, \"Citations\", separate=False, first=\"div\", follow=\"div\", direction_down=False)\n",
    "    # H-index\n",
    "    tinfo[\"H-index\"] = find_part_info(tbs, \"h-index\", separate=False, first=\"div\", follow=\"div\", direction_down=False)\n",
    "    # =====Personal Profile=======\n",
    "    tinfo[\"Personal Profile\"] = find_part_info(tbs, \"Personal profile\")\n",
    "    # Research Interests\n",
    "    tinfo[\"Research Interests\"] = find_part_info(tbs, \"Research interests\", separate=True)\n",
    "    # Experience\n",
    "    tinfo[\"Experience\"] = find_part_info(tbs, \"Experience\", separate=True)\n",
    "    # Teaching\n",
    "    tinfo[\"Teaching\"] = find_part_info(tbs, \"Teaching\", separate=True)\n",
    "    # Awards and honours\n",
    "    tinfo[\"Awards and Honours\"] = find_part_info(tbs, \"Awards and honours\", separate=True)\n",
    "    # ===========================\n",
    "    # =======Education==========\n",
    "    tinfo[\"Education\"] = find_part_info(tbs, \"Education/Academic qualification\", separate=True)\n",
    "    # Research Areas\n",
    "    tinfo[\"Research Areas\"] = find_part_info(tbs, \"Research areas\", separate=True, first=\"h3\", follow=\"ul\")\n",
    "    # Person Types\n",
    "    tinfo[\"Person Types\"] = find_part_info(tbs, \"Person Types\", separate=True, first=\"h3\", follow=\"ul\")\n",
    "    # ===========================\n",
    "    # Fingerprint\n",
    "    finger_print_url = overview_url + \"fingerprints/\"\n",
    "    tinfo[\"Fingerprint\"] = find_finger_prints(finger_print_url)\n",
    "    # Projects\n",
    "    projects_url = overview_url + \"projects/\"\n",
    "    tinfo[\"Projects\"] = find_xml_item(projects_url+\"?format=rss\")\n",
    "    for each_p in tinfo[\"Projects\"]:\n",
    "        if each_p[\"link\"]:\n",
    "            each_p.update(find_project_detail(each_p[\"link\"]))\n",
    "    # Publications\n",
    "    pub_url = overview_url + \"publications/\"\n",
    "    tinfo[\"Publications\"] = find_xml_item(pub_url+\"?format=rss\")\n",
    "    for each_p in tinfo[\"Publications\"]:\n",
    "        if each_p[\"link\"]:\n",
    "            each_p.update(find_project_detail(each_p[\"link\"]))\n",
    "    # Activities\n",
    "    act_url = overview_url + \"activities/\"\n",
    "    tinfo[\"Activities\"] = find_xml_item(act_url+\"?format=rss\")\n",
    "    for each_p in tinfo[\"Activities\"]:\n",
    "        if each_p[\"link\"]:\n",
    "            each_p.update(find_project_detail(each_p[\"link\"]))\n",
    "\n",
    "    # Similar Profiles\n",
    "    sbs = request_get_bs(overview_url+\"similar/\")\n",
    "    tinfo[\"Similar Profiles\"] = [each.text.strip() for each in sbs.find_all(\"a\", rel=\"Person\")]\n",
    "\n",
    "    return tinfo"
   ]
